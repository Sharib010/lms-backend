# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
VERCEL=1

# ── Database (MongoDB Atlas) ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gortt_lms?retryWrites=true&w=majority

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── CORS — comma-separated allowed frontend origins ───────────────────────────
CLIENT_URL=https://your-frontend.vercel.app,https://your-custom-domain.com

# ── Redis / BullMQ (optional — leave empty to disable background jobs) ────────
REDIS_URL=

# ── AWS (file storage / email) ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_SES_FROM_EMAIL=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Super Admin seed ──────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@gortt.gov.tt
SUPER_ADMIN_PASSWORD=
